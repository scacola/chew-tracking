# =============================================================================
# Chew Coach Landing — 환경변수 템플릿 (.env.example)
# =============================================================================
#
# 운영 모델:
#   - 로컬 개발: landing/.env (gitignore됨, 절대 커밋 X)
#   - 프로덕션 (GitHub Pages): GitHub repo Settings > Secrets and variables >
#     Actions에 VITE_* 모두 등록 + 빌드 워크플로 environment에 주입
#
# 정적 호스팅 보안 모델:
#   - 모든 VITE_* 값은 빌드 시 클라이언트 번들에 *인라인*된다 (공개로 간주).
#   - 따라서 Supabase service_role 키는 *절대 X*. anon 키만 (RLS와 한 세트).
#   - PostHog public key (phc_*)는 노출 의도된 설계.
#   - VITE_HASH_SALT는 노출돼도 무방 (rainbow table 회피용).
#
# 자세한 셋업: _workspace/landing/13_data_v2_consolidated.md §7

# === Supabase (영구 백엔드 — 컨택 source of truth) ============================
# Supabase Dashboard > Settings > API에서 복사
# 리전: Northeast Asia (Seoul) 우선, 미제공 시 Tokyo
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ_REPLACE_WITH_ANON_KEY

# === PostHog (분석 — 이벤트 ledger) ==========================================
# https://app.posthog.com → Project settings에서 복사
# Cloud US 표준 (한국 직접 리전 없음. 베타 트래픽 < 1M events/월 무료.)
# PIPA 위탁처리 고지 필요 — 약관·개인정보 처리 안내에 표기 예정.
VITE_POSTHOG_KEY=phc_REPLACE_ME_WITH_PROJECT_API_KEY
VITE_POSTHOG_HOST=https://us.i.posthog.com

# === 공통 (양 시스템에서 같은 값 사용) ========================================
# distinctId hash salt — sha256(email_lower + SALT)
# Supabase posthog_distinct_id 컬럼 = PostHog distinct_id (양쪽 동일 hash)
VITE_HASH_SALT=chew-coach-2026-public-salt

# 컨센트 약관 버전 — 약관 변경 시 ISO 날짜로 갱신
VITE_CONSENT_VERSION=2026-05-04

# === 마이그 패스 (Phase 5-B 도입과 함께 제거 예정) =============================
# 권장: 패스 B 즉시 컷오버 + 기존 가입자에게 재동의 메일.
# Day 1 ~ Day 7: Web3Forms 호출 유지 (병행 발송으로 fallback)
# Day 8+: 아래 변수 + 호출 코드 모두 제거
# VITE_W3FORMS_KEY=
